# --- DEPENDENCIES ---
node_modules/
**/node_modules/

# --- SECURITY & ENVIRONMENT ---
# This recursively hides .env files in root, backend, and frontend
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
*.pem
*.key

# --- BUILD & OUTPUT ---
dist/
build/
**/dist/
**/build/
.cache/

# --- IDE & SYSTEM FILES ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.log
npm-debug.log*

# --- PROJECT SPECIFIC ---
# Exclude local database files or temp uploads if they exist
/backend/db_backups/
/frontend/public/temp/